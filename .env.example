# Supabase (public — bundled to browser)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase (server-only — never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (server-only)
ANTHROPIC_API_KEY=your-anthropic-api-key

# ExamPulse cron (server-only) — Vercel sends Authorization: Bearer <CRON_SECRET>
CRON_SECRET=generate-a-long-random-string

# Jina Reader (server-only) — browser fallback for JS-heavy / chat share links
JINA_API_KEY=your-jina-api-key
